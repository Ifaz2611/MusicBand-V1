<AnchorPane prefHeight="712.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.music_band_oop.Controller.FXMLControllerForUser1.SE_Goal6_ViewController">

    <Label layoutX="24.0" layoutY="118.0" prefHeight="25.0" prefWidth="167.0" text="Selected Equipment:">

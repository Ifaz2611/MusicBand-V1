<AnchorPane prefHeight="570.0" prefWidth="755.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.music_band_oop.Controller.FXMLControllerForUser1.SE_Goal7_ViewController">
    
    <TableView fx:id="monitorTableView" layoutX="74.0" layoutY="179.0" prefHeight="250.0" prefWidth="376.0">

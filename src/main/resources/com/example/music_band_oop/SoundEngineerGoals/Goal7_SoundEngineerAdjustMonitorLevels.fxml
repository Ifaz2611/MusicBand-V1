        </columns>
    </TableView>

    <TextField fx:id="levelTextField" layoutX="525.0" layoutY="187.0" prefWidth="120.0" promptText="Enter level" />
    <Button layoutX="525.0" layoutY="227.0" onAction="#AdjustButtonOnAction" text="Adjust Monitor Level" />
    <Label fx:id="feedbackLabel" layoutX="466.0" layoutY="92.0" prefHeight="52.0" prefWidth="277.0" />
    <Button layoutX="525.0" layoutY="267.0" onAction="#VerifyButtonOnAction" text="Verify Balance" />
    <Button layoutX="525.0" layoutY="307.0" onAction="#SaveLogButtonOnAction" text="Save Adjustment Log" />
   <Label alignment="CENTER" layoutX="169.0" layoutY="22.0" prefHeight="52.0" prefWidth="402.0" style="-fx-background-color: cyan;" text="Monitor Control Dashboard">

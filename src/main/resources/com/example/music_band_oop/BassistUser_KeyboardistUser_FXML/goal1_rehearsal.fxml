<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="699.0" prefWidth="835.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.music_band_oop.Controller.BassistUser_KeyboardistUser_Controller.RehearsalController">
    <children>
        <Label layoutX="35.0" layoutY="28.0" text="Rehearsal Schedule" textFill="#ab4f4f">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>
        <TableView fx:id="rehearsal_schedule_tableView" layoutX="35.0" layoutY="88.0" prefHeight="285.0" prefWidth="760.0">
            <columns>
                <TableColumn fx:id="date_column" prefWidth="168.0" text="Date" />
                <TableColumn fx:id="time_column" prefWidth="186.0" text="Time " />
                <TableColumn fx:id="vanue_column" prefWidth="195.0" text="Vanue" />
                <TableColumn fx:id="status_column" prefWidth="210.0" text="Status" />
            </columns>
        </TableView>
        <Button layoutX="38.0" layoutY="397.0" mnemonicParsing="false" onAction="#confirmSchdule_btn" prefHeight="25.0" prefWidth="358.0" text="Confirm Schedule" textFill="#dd2e2e" />
        <Button layoutX="440.0" layoutY="397.0" mnemonicParsing="false" onAction="#cancel_scedule_btn" prefHeight="25.0" prefWidth="358.0" text="Cancel Schedule" textFill="#dd2e2e" />
        <Label fx:id="message_label" layoutX="38.0" layoutY="441.0" prefHeight="17.0" prefWidth="329.0" text="Select a row to confirm or cancel schedule" textFill="#dd2e2e" />
    </children>
</AnchorPane>

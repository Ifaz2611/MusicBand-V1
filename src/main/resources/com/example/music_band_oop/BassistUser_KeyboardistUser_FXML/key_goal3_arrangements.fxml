<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="658.0" prefWidth="835.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.music_band_oop.Controller.BassistUser_KeyboardistUser_Controller.KeyGoal3ArrangementsController">

    <children>
        <!-- Title -->
        <Label layoutX="30.0" layoutY="28.0" text="Song Arrangements (Keyboardist)" textFill="#ab4f4f">
         <font>
            <Font name="System Bold" size="20.0" />
         </font></Label>

        <!-- TableView for arrangements -->
        <TableView fx:id="arrangementsTableView" layoutX="30.0" layoutY="79.0" prefHeight="192.0" prefWidth="775.0">
            <columns>
                <TableColumn fx:id="colEvent" prefWidth="135.0" text="Event" />
                <TableColumn fx:id="colSong" prefWidth="135.0" text="Song Title" />
                <TableColumn fx:id="colTempo" prefWidth="119.0" text="Tempo" />
                <TableColumn fx:id="colKey" prefWidth="133.0" text="Key" />
                <TableColumn fx:id="colPatch" prefWidth="138.0" text="Synth Patch" />
                <TableColumn fx:id="colReviewed" prefWidth="119.0" text="Reviewed" />
            </columns>
        </TableView>

        <!-- Selected arrangement details -->
        <Label layoutX="30.0" layoutY="302.0" text="Selected Arrangement Details:" textFill="#ab4f4f">
         <font>
            <Font name="System Bold" size="13.0" />
         </font></Label>

        <Label layoutX="27.0" layoutY="359.0" text="Patch / Sound Notes:" textFill="#ab4f4f" />
        <TextArea fx:id="patchNotesTextArea" editable="false" layoutX="174.0" layoutY="339.0" prefHeight="60.0" prefWidth="472.0" wrapText="true" />

        <Label layoutX="30.0" layoutY="436.0" text="MIDI File Reference:" textFill="#ab4f4f" />
        <TextArea fx:id="midiTextArea" editable="false" layoutX="174.0" layoutY="416.0" prefHeight="60.0" prefWidth="472.0" wrapText="true" />

        <Label layoutX="30.0" layoutY="519.0" text="Sheet Music / Notation:" textFill="#ab4f4f" />
        <TextArea fx:id="sheetMusicTextArea" editable="false" layoutX="174.0" layoutY="499.0" prefHeight="60.0" prefWidth="472.0" wrapText="true" />

        <!-- Mark as Reviewed button -->
        <Button layoutX="659.0" layoutY="338.0" onAction="#markReviewedBtn" prefHeight="222.0" prefWidth="146.0" text="Mark as Reviewed" textFill="#ab4f4f">
         <font>
            <Font name="System Bold" size="13.0" />
         </font></Button>

        <!-- Message label -->
        <Label fx:id="messageLabel" layoutX="37.0" layoutY="585.0" prefHeight="30.0" prefWidth="769.0" text="" />
    </children>
</AnchorPane>

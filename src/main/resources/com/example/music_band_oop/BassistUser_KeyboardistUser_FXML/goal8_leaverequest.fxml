<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="561.0" prefWidth="776.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.music_band_oop.Controller.BassistUser_KeyboardistUser_Controller.LeaveRequestController">

    <children>
        <!-- Title -->
        <Label fx:id="titleLabel" layoutX="30.0" layoutY="26.0" text="Leave Request / Availability" textFill="#dd2e2e">
         <font>
            <Font name="System Bold" size="20.0" />
         </font></Label>

        <!-- Start Date -->
        <Label layoutX="31.0" layoutY="80.0" text="Start Date:" textFill="#ab4f4f" />
        <DatePicker fx:id="startDatePicker" layoutX="112.0" layoutY="76.0" prefWidth="180.0" />

        <!-- End Date -->
        <Label layoutX="31.0" layoutY="120.0" text="End Date:" textFill="#ab4f4f" />
        <DatePicker fx:id="endDatePicker" layoutX="112.0" layoutY="116.0" prefWidth="180.0" />

        <!-- Reason -->
        <Label layoutX="334.0" layoutY="101.0" text="Reason:" textFill="#ab4f4f" />
        <TextField fx:id="reasonTextField" layoutX="391.0" layoutY="76.0" prefHeight="64.0" prefWidth="336.0" promptText="e.g., Exam, Sick, Personal" />

        <!-- Leave Type (RadioButtons) -->
        <Label layoutX="30.0" layoutY="178.0" text="Leave Type:" textFill="#ab4f4f" />
        <RadioButton fx:id="sickRadio" layoutX="120.0" layoutY="178.0" text="Sick Leave" textFill="#da3131" />
        <RadioButton fx:id="personalRadio" layoutX="223.0" layoutY="178.0" text="Personal Leave" textFill="#da3131" />
        <RadioButton fx:id="examRadio" layoutX="348.0" layoutY="178.0" text="Exam / Academic" textFill="#da3131" />

        <!-- Submit Button -->
        <Button layoutX="505.0" layoutY="174.0" onAction="#submitBtn" prefHeight="25.0" prefWidth="217.0" text="Submit Leave Request" textFill="#ab4f4f" />

        <!-- Message Label -->
        <Label fx:id="messageLabel" layoutX="31.0" layoutY="210.0" prefHeight="25.0" prefWidth="238.0" text="" textFill="#a42929" />

        <!-- Existing Requests Table -->
        <Label layoutX="31.0" layoutY="244.0" text="My Leave Requests" textFill="#ab4f4f" />
        <TableView fx:id="leaveTableView" layoutX="31.0" layoutY="274.0" prefHeight="245.0" prefWidth="705.0">
            <columns>
                <TableColumn fx:id="colStartDate" prefWidth="104.0" text="Start Date" />
                <TableColumn fx:id="colEndDate" prefWidth="118.0" text="End Date" />
                <TableColumn fx:id="colReason" prefWidth="130.0" text="Reason" />
                <TableColumn fx:id="colType" prefWidth="117.0" text="Type" />
                <TableColumn fx:id="colStatus" prefWidth="115.0" text="Status" />
                <TableColumn fx:id="colDays" prefWidth="120.0" text="Total Days" />
            </columns>
        </TableView>
    </children>
</AnchorPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="577.0" prefWidth="840.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.music_band_oop.Controller.BassistUser_KeyboardistUser_Controller.UploadController">

    <children>
        <!-- Title -->
        <Label fx:id="titleLabel" layoutX="32.0" layoutY="29.0" text="Upload Practice Recording" textFill="#dd2e2e">
         <font>
            <Font name="System Bold" size="20.0" />
         </font></Label>

        <!-- Event selection -->
        <Label fx:id="eventLabel" layoutX="32.0" layoutY="95.0" text="Select Event:" textFill="#ab4f4f" />
        <ComboBox fx:id="eventComboBox" layoutX="132.0" layoutY="91.0" prefWidth="200.0" promptText="Choose an event" />

        <!-- Recording title -->
        <Label fx:id="titleFieldLabel" layoutX="32.0" layoutY="135.0" text="Recording Title:" textFill="#ab4f4f" />
        <TextField fx:id="titleTextField" layoutX="132.0" layoutY="131.0" prefHeight="25.0" prefWidth="200.0" />

        <!-- Notes / Description -->
        <Label fx:id="notesLabel" layoutX="32.0" layoutY="185.0" text="Notes (optional):" textFill="#ab4f4f" />
        <TextArea fx:id="notesTextArea" layoutX="132.0" layoutY="181.0" prefHeight="80.0" prefWidth="200.0" promptText="Practice notes, focus areas, etc." />

        <!-- File selection -->
        <Label fx:id="fileLabel" layoutX="406.0" layoutY="95.0" text="Audio File:" textFill="#ab4f4f" />
        <Button layoutX="483.0" layoutY="91.0" onAction="#chooseFileBtn" text="Choose File" textFill="#ab4f4f" />
        <Label fx:id="filePathLabel" layoutX="481.0" layoutY="135.0" text="No file selected" textFill="#ab4f4f" />

        <!-- Upload button -->
        <Button layoutX="406.0" layoutY="190.0" onAction="#uploadBtn" prefHeight="69.0" prefWidth="161.0" text="Upload Recording" textFill="#ab4f4f" />

        <!-- TableView of past uploads -->
        <Label fx:id="uploadHistoryLabel" layoutX="32.0" layoutY="288.0" text="My Uploads" textFill="#d73838">
         <font>
            <Font size="14.0" />
         </font></Label>
        <TableView fx:id="uploadTableView" layoutX="32.0" layoutY="318.0" prefHeight="200.0" prefWidth="780.0">
            <columns>
                <TableColumn fx:id="colTitle" prefWidth="200" text="Title" />
                <TableColumn fx:id="colEvent" prefWidth="200" text="Event" />
                <TableColumn fx:id="colDate" prefWidth="150" text="Date" />
                <TableColumn fx:id="colNotes" prefWidth="230" text="Notes" />
            </columns>
        </TableView>

        <!-- Message label -->
        <Label fx:id="messageLabel" layoutX="34.0" layoutY="528.0" prefHeight="30.0" prefWidth="189.0" text="" />
    </children>

</AnchorPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="619.0" prefWidth="835.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.music_band_oop.Controller.BassistUser_KeyboardistUser_Controller.KeyGoal1RehearsalController">

    <children>
        <!-- Title -->
        <Label layoutX="29.0" layoutY="30.0" text="Rehearsal Schedule (Keyboardist)" textFill="#ab4f4f">
         <font>
            <Font name="System Bold" size="20.0" />
         </font></Label>

        <!-- TableView for rehearsals -->
        <TableView fx:id="rehearsalTableView" layoutX="29.0" layoutY="82.0" prefHeight="250.0" prefWidth="780.0">
            <columns>
                <TableColumn fx:id="colDate" prefWidth="100" text="Date" />
                <TableColumn fx:id="colTime" prefWidth="96.0" text="Time" />
                <TableColumn fx:id="colDuration" prefWidth="103.0" text="Duration" />
                <TableColumn fx:id="colVenue" prefWidth="128.0" text="Venue" />
                <TableColumn fx:id="colStatus" prefWidth="135.0" text="Status" />
                <TableColumn fx:id="colKeyboardNotes" prefWidth="218.0" text="Keyboard Notes" />
            </columns>
        </TableView>

        <!-- Selected Rehearsal Details -->
        <Label layoutX="29.0" layoutY="349.0" text="Selected Rehearsal Details:" textFill="#ab4f4f">
         <font>
            <Font name="System Bold" size="13.0" />
         </font></Label>

        <Label layoutX="29.0" layoutY="374.0" text="Duration:" textFill="#ab4f4f" />
        <Label fx:id="durationValueLabel" layoutX="90.0" layoutY="355.0" text="-" />

        <Label layoutX="29.0" layoutY="399.0" text="Band Manager Notes:" textFill="#ab4f4f" />
        <TextArea fx:id="bandManagerNotesTextArea" editable="false" layoutX="29.0" layoutY="419.0" prefHeight="60.0" prefWidth="400.0" wrapText="true" />

        <Label layoutX="29.0" layoutY="494.0" text="Required Equipment:" textFill="#ab4f4f" />
        <TextArea fx:id="equipmentTextArea" editable="false" layoutX="29.0" layoutY="514.0" prefHeight="50.0" prefWidth="400.0" wrapText="true" />

        <!-- Confirmation Buttons -->
        <Button layoutX="459.0" layoutY="419.0" onAction="#confirmBtn" prefWidth="180" text="Confirm Participation" textFill="#ab4f4f" />
        <Button layoutX="659.0" layoutY="419.0" onAction="#rescheduleBtn" prefHeight="25.0" prefWidth="156.0" text="Request Reschedule" textFill="#ab4f4f" />

        <!-- Reason for reschedule -->
        <Label layoutX="459.0" layoutY="459.0" text="Reason (if rescheduling):" textFill="#ab4f4f" />
        <TextArea fx:id="reasonTextArea" layoutX="459.0" layoutY="479.0" prefHeight="82.0" prefWidth="360.0" promptText="Enter reason for rescheduling..." />

        <!-- Message Label -->
        <Label fx:id="messageLabel" layoutX="29.0" layoutY="578.0" prefHeight="25.0" prefWidth="790.0" text="" />
      <Line endX="100.0" endY="38.0" layoutX="343.0" layoutY="382.0" startX="100.0" startY="182.0" stroke="#0000004c" />
    </children>
</AnchorPane>

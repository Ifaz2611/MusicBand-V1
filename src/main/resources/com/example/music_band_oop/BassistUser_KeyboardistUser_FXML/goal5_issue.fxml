<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="664.0" prefWidth="861.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.music_band_oop.Controller.BassistUser_KeyboardistUser_Controller.IssueController">

    <children>
        <!-- Title -->
        <Label fx:id="titleLabel" layoutX="40.0" layoutY="32.0" text="Report Equipment Issue" textFill="#dd2e2e">
         <font>
            <Font name="System Bold" size="20.0" />
         </font></Label>

        <!-- Event selection -->
        <Label fx:id="eventLabel" layoutX="40.0" layoutY="87.0" text="Select Event:" textFill="#ab4f4f" />
        <ComboBox fx:id="eventComboBox" layoutX="122.0" layoutY="83.0" prefWidth="200.0" promptText="Choose an event" />

        <!-- Equipment name -->
        <Label fx:id="equipmentLabel" layoutX="383.0" layoutY="87.0" text="Equipment Name:" textFill="#ab4f4f" />
        <TextField fx:id="equipmentTextField" layoutX="501.0" layoutY="83.0" prefWidth="250.0" promptText="e.g., Bass Amp, Cable, Tuner" />

        <!-- Issue description -->
        <Label fx:id="descriptionLabel" layoutX="40.0" layoutY="145.0" text="Issue Description:" textFill="#ab4f4f" />
        <TextArea fx:id="descriptionTextArea" layoutX="144.0" layoutY="145.0" prefHeight="100.0" prefWidth="605.0" promptText="Describe the problem in detail..." />

        <!-- Submit button -->
        <Button layoutX="385.0" layoutY="262.0" onAction="#submitBtn" text="Submit Issue Report" textFill="#ab4f4f" />

        <!-- TableView of reported issues -->
        <Label fx:id="issueHistoryLabel" layoutX="40.0" layoutY="317.0" text="My Reported Issues" textFill="#ab4f4f" />
        <TableView fx:id="issueTableView" layoutX="41.0" layoutY="345.0" prefHeight="250.0" prefWidth="780.0">
            <columns>
                <TableColumn fx:id="colId" prefWidth="80" text="Issue ID" />
                <TableColumn fx:id="colEvent" prefWidth="180" text="Event" />
                <TableColumn fx:id="colEquipment" prefWidth="150" text="Equipment" />
                <TableColumn fx:id="colStatus" prefWidth="120" text="Status" />
                <TableColumn fx:id="colDate" prefWidth="120" text="Date Reported" />
                <TableColumn fx:id="colDescription" prefWidth="130" text="Description" />
            </columns>
        </TableView>

        <!-- Message label -->
        <Label fx:id="messageLabel" layoutX="41.0" layoutY="607.0" prefHeight="25.0" prefWidth="457.0" text="" />
      <TextField fx:id="filter_input" layoutX="562.0" layoutY="313.0" promptText="Filter Data" />
      <Button layoutX="725.0" layoutY="313.0" mnemonicParsing="false" onAction="#filter_btn" prefHeight="25.0" prefWidth="93.0" text="Filter" />
    </children>

</AnchorPane>

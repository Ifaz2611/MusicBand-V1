<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="699.0" prefWidth="835.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.music_band_oop.Controller.BassistUser_KeyboardistUser_Controller.KeyGoal7AvailabilityController">

    <children>
        <!-- Title -->
        <Label layoutX="31.0" layoutY="30.0" text="Availability Management (Leave Request)" textFill="#ab4f4f">
         <font>
            <Font name="System Bold" size="20.0" />
         </font></Label>

        <!-- Start Date -->
        <Label layoutX="31.0" layoutY="83.0" text="Start Date:" textFill="#ab4f4f" />
        <DatePicker fx:id="startDatePicker" layoutX="131.0" layoutY="79.0" prefWidth="180.0" />

        <!-- End Date -->
        <Label layoutX="31.0" layoutY="123.0" text="End Date:" textFill="#ab4f4f" />
        <DatePicker fx:id="endDatePicker" layoutX="131.0" layoutY="119.0" prefWidth="180.0" />

        <!-- Reason -->
        <Label layoutX="31.0" layoutY="163.0" text="Reason:" textFill="#ab4f4f" />
        <TextField fx:id="reasonTextField" layoutX="131.0" layoutY="159.0" prefHeight="75.0" prefWidth="180.0" promptText="e.g., Exam, Sick, Personal" />

        <!-- Submit Button -->
        <Button layoutX="327.0" layoutY="159.0" onAction="#submitBtn" prefHeight="75.0" prefWidth="157.0" text="Submit Leave Request" textFill="#ab4f4f">
         <font>
            <Font name="System Bold" size="13.0" />
         </font></Button>

        <!-- Message Label -->
        <Label fx:id="messageLabel" layoutX="188.0" layoutY="249.0" prefHeight="25.0" prefWidth="505.0" text="" />

        <!-- Existing Leave Requests Table -->
        <Label layoutX="31.0" layoutY="252.0" text="My Leave Requests" textFill="#ab4f4f">
         <font>
            <Font name="System Bold" size="13.0" />
         </font></Label>

        <!-- Filter for table -->
        <Label layoutX="31.0" layoutY="293.0" text="Filter by status:" textFill="#ab4f4f" />
        <TextField fx:id="filterTextField" layoutX="141.0" layoutY="289.0" prefWidth="150.0" promptText="e.g., Pending, Approved" />
        <Button layoutX="311.0" layoutY="289.0" onAction="#filterButton" text="Filter" textFill="#ab4f4f" />
        <Button layoutX="371.0" layoutY="289.0" onAction="#resetFilterButton" text="Reset" textFill="#ab4f4f" />

        <TableView fx:id="leaveTableView" layoutX="31.0" layoutY="323.0" prefHeight="280.0" prefWidth="766.0">
            <columns>
                <TableColumn fx:id="colStartDate" prefWidth="131.0" text="Start Date" />
                <TableColumn fx:id="colEndDate" prefWidth="118.0" text="End Date" />
                <TableColumn fx:id="colReason" prefWidth="176.0" text="Reason" />
                <TableColumn fx:id="colStatus" prefWidth="166.0" text="Status" />
                <TableColumn fx:id="colDays" prefWidth="174.0" text="Total Days" />
            </columns>
        </TableView>
    </children>
</AnchorPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="624.0" prefWidth="680.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.music_band_oop.dashboardController">
    <children>
        <Text layoutX="220.0" layoutY="100.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Dashboard" wrappingWidth="200.0">
            <font>
                <Font name="System Bold" size="32.0" />
            </font>
        </Text>
        <Text fx:id="welcomeText" layoutX="180.0" layoutY="200.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Welcome!" wrappingWidth="300.0">
            <font>
                <Font size="18.0" />
            </font>
        </Text>
        <Button fx:id="LogoutButton" layoutX="280.0" layoutY="300.0" mnemonicParsing="false" prefHeight="40.0" prefWidth="100.0" text="Logout" onAction="#onLogoutClick" />
    </children>
</AnchorPane>
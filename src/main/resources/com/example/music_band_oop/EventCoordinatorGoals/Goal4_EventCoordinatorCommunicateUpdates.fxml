<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="630.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.music_band_oop.Controller.FXMLControllerForUser2.EC_Goal4_ViewController">
    <Label layoutX="30.0" layoutY="125.0" text="Select Event:" />
    <ComboBox fx:id="EventComboBox" layoutX="130.0" layoutY="120.0" prefWidth="200" promptText="Choose event" />
    <Label layoutX="30.0" layoutY="172.0" text="Message:" />
    <TextField fx:id="MessageTextField" layoutX="130.0" layoutY="167.0" prefWidth="400" promptText="Schedule change, venue change, etc." />
    <Label layoutX="27.0" layoutY="222.0" text="Recipients:" />
    <CheckBox fx:id="BandCheckBox" layoutX="130.0" layoutY="222.0" text="Band" />
    <CheckBox fx:id="SoundCheckBox" layoutX="210.0" layoutY="222.0" text="Sound Engineer" />
    <CheckBox fx:id="VenueCheckBox" layoutX="340.0" layoutY="222.0" text="Venue Staff" />
    <Button layoutX="31.0" layoutY="271.0" onAction="#SendMessageButtonOnAction" prefWidth="120" text="Send Message" />
    <Label layoutX="27.0" layoutY="322.0" text="Communication History:" />
    <TableView fx:id="HistoryTableViw" layoutX="23.0" layoutY="358.0" prefHeight="200" prefWidth="650">
        <columns>
            <TableColumn fx:id="EventCol" prefWidth="150" text="Event" />
            <TableColumn fx:id="MessageCol" prefWidth="153.0" text="Message" />
            <TableColumn fx:id="RecipientsCol" prefWidth="151.0" text="Recipients" />
            <TableColumn fx:id="TimestampCol" prefWidth="196.0" text="Time" />
        </columns>
    </TableView>
   <Label alignment="CENTER" layoutX="115.0" layoutY="24.0" prefHeight="40.0" prefWidth="470.0" style="-fx-background-color: cyan;" text="Communication Panel Dashboard">
      <font>
         <Font name="System Bold Italic" size="23.0" />
      </font>
   </Label>
   <Button layoutX="595.0" layoutY="584.0" mnemonicParsing="false" onAction="#DashboardButtonOnAction" text="Dashboard" />
</AnchorPane>

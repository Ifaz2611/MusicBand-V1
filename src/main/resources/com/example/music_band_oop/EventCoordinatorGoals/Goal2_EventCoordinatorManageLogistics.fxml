<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="705.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.music_band_oop.Controller.FXMLControllerForUser2.EC_Goal2_ViewController">
    <TableView fx:id="LogisticsTableView" layoutX="150.0" layoutY="113.0" prefHeight="200.0" prefWidth="399.0">
        <columns>
            <TableColumn fx:id="LogisticsAspectCol" prefWidth="120" text="Logistics Aspect" />
            <TableColumn fx:id="ValueCol" prefWidth="150" text="Current Value" />
            <TableColumn fx:id="StatusCol" prefWidth="129.0" text="Status" />
        </columns>
    </TableView>
    <TextField fx:id="ValueTextField" layoutX="200.0" layoutY="336.0" prefWidth="300.0" promptText="Enter new value for selected aspect" />
    <Button layoutX="322.0" layoutY="389.0" onAction="#UpdateValueButtonOnAction" text="Update" />
    <Button layoutX="54.0" layoutY="452.0" onAction="#VerifyReadinessButtonOnAction" prefWidth="150" text="Verify Readiness" />
    <Button layoutX="232.0" layoutY="452.0" onAction="#confirmLogisticsPlanOnAction" prefWidth="180" text="Confirm Logistics Plan" />
    <Button layoutX="444.0" layoutY="451.0" onAction="#notifyUsersButtonOnAction" prefWidth="180" text="Notify All Concerned" />
    <TextArea fx:id="logTextArea" layoutX="30.0" layoutY="509.0" prefHeight="80.0" prefWidth="640.0" wrapText="true" />
   <Label alignment="CENTER" layoutX="156.0" layoutY="28.0" prefHeight="53.0" prefWidth="366.0" style="-fx-background-color: cyan;" text="Event Logistics Management">
      <font>
         <Font name="System Bold Italic" size="23.0" />
      </font>
   </Label>
   <Button layoutX="596.0" layoutY="644.0" mnemonicParsing="false" onAction="#DashboardButtonOnAction" text="Dashboard" />

</AnchorPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="550.0" prefWidth="891.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.music_band_oop.Controller.FXMLControllerForUser2.EC_Goal8_ViewController">
    <Label layoutX="30.0" layoutY="90.0" text="Select Completed Event:" />
    <ComboBox fx:id="EventComboBox" layoutX="180.0" layoutY="85.0" prefWidth="250.0" />
    <Button layoutX="450.0" layoutY="85.0" onAction="#LoadPaymentButtonOnAction" text="Load Payments" />
    <TableView fx:id="PaymentTableView" layoutX="30.0" layoutY="130.0" prefHeight="200.0" prefWidth="740.0">
        <columns>
            <TableColumn fx:id="VendorNameCol" prefWidth="180.0" text="Vendor/Recipient" />
            <TableColumn fx:id="ExpenseTypeCol" prefWidth="127.0" text="Expense Type" />
            <TableColumn fx:id="AmountCol" prefWidth="112.0" text="Amount ($)" />
            <TableColumn fx:id="PaymentCol" prefWidth="161.0" text="Payment Status" />
            <TableColumn fx:id="VerifiedCol" prefWidth="159.0" text="Verified" />
        </columns>
    </TableView>
    <Button layoutX="30.0" layoutY="350.0" onAction="#VerifyPaymentButtonOnAction" text="Verify Payments" />
    <Button layoutX="160.0" layoutY="350.0" onAction="#UpdatePaymentRecordButtonOnAction" text="Update Payment Record" />
    <Button layoutX="335.0" layoutY="350.0" onAction="#WriteEventNotesButtonOnAction" text="Write Event Notes" />
    <Button layoutX="480.0" layoutY="350.0" onAction="#SendThankYouMessagesButtonOnAction" text="Send Thank-You Messages" />
    <Button layoutX="650.0" layoutY="350.0" onAction="#GenerateReportButtonOnAction" text="Generate Report" />
    <Label layoutX="30.0" layoutY="400.0" text="Event Notes / Lessons Learned:" />
    <TextArea fx:id="NotesTextArea" layoutX="30.0" layoutY="420.0" prefHeight="80.0" prefWidth="690.0" promptText="Write any notes, issues, or lessons learned from this event..." />
    <Button layoutX="774.0" layoutY="500.0" onAction="#DashboardButtonOnAction" text=" Dashboard" />
   <Label alignment="CENTER" layoutX="182.0" layoutY="14.0" prefHeight="39.0" prefWidth="497.0" style="-fx-background-color: cyan;" text="Event Closing Dashboard">
      <font>
         <Font name="System Bold Italic" size="23.0" />
      </font></Label>
</AnchorPane>
